<Project>
    <PropertyGroup Label="SDK Version (Auto-generated)">
        <ANcpSdkPackageVersion>999.9.9</ANcpSdkPackageVersion>
    </PropertyGroup>
    <PropertyGroup Label=".NET SDK">
        <DotNetSdkVersion>10.0.301</DotNetSdkVersion>
        <DotNetSdkRollForward>latestMinor</DotNetSdkRollForward>
    </PropertyGroup>

    <PropertyGroup Label="Roslyn">
        <RoslynVersion>5.6.0</RoslynVersion>
        <RoslynAnalyzersVersion>5.6.0</RoslynAnalyzersVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ROSLYN ANALYZER TESTING
         Used by: Roslyn.Utilities.Testing, Analyzers.Tests
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Analyzer Testing">
        <AnalyzerTestingVersion>1.1.4</AnalyzerTestingVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         REFERENCE ASSEMBLIES
         Used by: Roslyn.Utilities.Testing, Analyzers.Tests
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Reference Assemblies">
        <BasicReferenceAssembliesVersion>1.8.9</BasicReferenceAssembliesVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MEZIANTOU PACKAGES
         Used by: SDK, Roslyn.Utilities
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Meziantou">
        <!-- Held at 5.0.15 (verified 2026-07-16): 5.0.16+ marks ProcessStartInfo.RunAsTaskAsync /
             ProcessOutputCollection [Obsolete] (14x CS0618) and 6.0 removes them (redesigned into
             Meziantou.Framework.ProcessWrapper's ProcessWrapper/ProcessInstance API). BuildResult
             exposes ProcessOutputCollection in Roslyn.Utilities.Testing's PUBLIC API, so moving off
             it is a deliberate breaking change for consumers — migrate the MSBuild plumbing
             (5 call sites + BuildResult surface) first, then bump to 6.x. -->
        <MeziantouFrameworkVersion>5.0.15</MeziantouFrameworkVersion>
        <MeziantouFullPathVersion>3.0.1</MeziantouFullPathVersion>
        <MeziantouTemporaryDirectoryVersion>3.0.1</MeziantouTemporaryDirectoryVersion>
        <MeziantouThreadingVersion>3.0.0</MeziantouThreadingVersion>
        <MeziantouAnalyzerVersion>3.0.123</MeziantouAnalyzerVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         TESTING FRAMEWORKS
         Used by: SDK, Roslyn.Utilities.Testing, Analyzers.Tests
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Testing">
        <XunitV3Version>3.2.2</XunitV3Version>
        <NUnitVersion>4.6.1</NUnitVersion>
        <TUnitCoreVersion>1.60.0</TUnitCoreVersion>
        <BunitVersion>2.7.2</BunitVersion>
        <AngleSharpVersion>1.5.2</AngleSharpVersion>
        <AwesomeAssertionsVersion>9.4.0</AwesomeAssertionsVersion>
        <AwesomeAssertionsAnalyzersVersion>9.0.8</AwesomeAssertionsAnalyzersVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MICROSOFT TESTING PLATFORM (MTP) EXTENSIONS
         Used by: SDK (auto-injected for TUnit, NUnit MTP, MSTest MTP)
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="MTP Extensions">
        <MTPExtensionsVersion>2.3.2</MTPExtensionsVersion>
        <CodeCoverageVersion>18.9.0</CodeCoverageVersion>
        <TestSdkVersion>18.8.1</TestSdkVersion>
        <DiagnosticsTestingVersion>10.8.0</DiagnosticsTestingVersion>
        <GitHubActionsLoggerMTPVersion>3.0.4</GitHubActionsLoggerMTPVersion>
        <GitHubActionsLoggerVSTestVersion>2.4.1</GitHubActionsLoggerVSTestVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         ANALYZERS (SDK-injected)
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Analyzers">
        <ANcpLuaAnalyzersVersion>2.1.1</ANcpLuaAnalyzersVersion>
        <SbomTargetsVersion>4.1.5</SbomTargetsVersion>
        <BannedApiAnalyzersVersion>5.6.0</BannedApiAnalyzersVersion>
        <JonSkeetAnalyzersVersion>1.0.0-beta.7</JonSkeetAnalyzersVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MICROSOFT.EXTENSIONS (BCL polyfills, diagnostics, AI abstractions)
         Used by: Roslyn.Utilities (BCL polyfills), Roslyn.Utilities.Testing
         (AI.Abstractions, Diagnostics.Testing, Mvc.Testing, OpenAI)
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Microsoft.Extensions">
        <MicrosoftExtensionsVersion>10.8.0</MicrosoftExtensionsVersion>
        <MicrosoftExtensionsAIAbstractionsVersion>10.8.0</MicrosoftExtensionsAIAbstractionsVersion>
        <AspNetCoreVersion>10.0.10</AspNetCoreVersion>
        <BclHashCodeVersion>6.0.0</BclHashCodeVersion>
        <SystemThreadingChannelsVersion>10.0.10</SystemThreadingChannelsVersion>
        <OpenAIVersion>2.12.0</OpenAIVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         OPENTELEMETRY
         Used by: Web projects (qyl ServiceDefaults)
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="OpenTelemetry">
        <OpenTelemetryVersion>1.16.0</OpenTelemetryVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         NUGET / BUILD TOOLS
         Used by: SDK
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Build Tools">
        <NuGetVersion>7.6.0</NuGetVersion>
        <MSBuildStructuredLoggerVersion>2.3.213</MSBuildStructuredLoggerVersion>
        <MicrosoftSourceLinkVersion>10.0.301</MicrosoftSourceLinkVersion>
        <MicrosoftDeploymentDotNetReleasesVersion>1.0.2</MicrosoftDeploymentDotNetReleasesVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MISCELLANEOUS
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Misc">
        <JetBrainsAnnotationsVersion>2026.2.0</JetBrainsAnnotationsVersion>
    </PropertyGroup>

    <!-- ═══════════════════════════════════════════════════════════════════════
         LEGACY ALIASES (backward compatibility)
         ═══════════════════════════════════════════════════════════════════════ -->
    <PropertyGroup Label="Aliases">
        <XunitMtpVersion>$(XunitV3Version)</XunitMtpVersion>
    </PropertyGroup>
</Project>
